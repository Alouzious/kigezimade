# Neon PostgreSQL connection string
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/kigezimade?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/kigezimade

# Groq API key for story generation and translation
# Get one at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Server port (Render sets this automatically in production)
PORT=3000

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:5173

# JWT secret for artisan sessions (change in production!)
JWT_SECRET=your-long-random-secret-here

# Frontend URL for password reset links
FRONTEND_URL=http://localhost:5173

# In-memory API cache TTL in seconds (products, artisans). Default: 120
CACHE_TTL_SECS=120

# Optional — order email notifications (Gmail, SendGrid, Mailgun, etc.)
# If not set, orders still work but no emails are sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Kigezi Made <noreply@kigezimade.ug>
